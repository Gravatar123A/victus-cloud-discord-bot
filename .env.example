# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_GUILD_ID=your_discord_server_id_here
DISCORD_SUPPORT_GUILD_ID=your_main_support_server_id
DISCORD_LINKED_ROLE_ID=your_linked_member_role_id

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Victus Cloud API (optional - for direct API access)
VICTUS_API_URL=https://victuscloud.xyz/api
VICTUS_API_KEY=your_victus_api_key

# Pterodactyl Panel (if bypassing Supabase)
PTERODACTYL_URL=https://panel.victuscloud.xyz
PTERODACTYL_API_KEY=your_pterodactyl_api_key

# Paymenter (if bypassing Supabase)  
PAYMENTER_URL=https://billing.victuscloud.xyz
PAYMENTER_API_KEY=your_paymenter_api_key

# AI Support (optional)
OPENAI_API_KEY=your_openai_api_key

# Bot Settings
BOT_PREFIX=!
LINK_TOKEN_EXPIRY_MINUTES=10
LOG_LEVEL=info
