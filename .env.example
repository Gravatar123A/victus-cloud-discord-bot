# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_GUILD_ID=your_discord_server_id_here
DISCORD_SUPPORT_GUILD_ID=your_main_support_server_id
DISCORD_LINKED_ROLE_ID=your_linked_member_role_id
DISCORD_AI_CHANNEL_ID=
DISCORD_AUTO_REGISTER_COMMANDS=true

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Victus Cloud API (optional - for direct API access)
VICTUS_API_URL=https://victuscloud.com/api
VICTUS_API_KEY=your_victus_api_key

# Pterodactyl Panel (if bypassing Supabase)
PTERODACTYL_URL=
PTERODACTYL_API_KEY=your_pterodactyl_api_key
PTERODACTYL_CLIENT_API_KEY=your_pterodactyl_client_api_key_for_power_actions

# Paymenter (if bypassing Supabase)  
PAYMENTER_URL=
PAYMENTER_API_KEY=your_paymenter_api_key

# AI Support (optional, Groq OpenAI-compatible chat)
# Only GROQ_API_KEY is required. The model/base URL defaults are built into the bot.
GROQ_API_KEY=your_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.35
GROQ_MAX_TOKENS=700
# Optional extra system instructions appended after the built-in Victus Cloud support prompt
VICTUS_AI_SYSTEM_PROMPT=

# Bot Settings
BOT_PREFIX=!
LINK_TOKEN_EXPIRY_MINUTES=10
LOG_LEVEL=info

# Lavalink (music) — defaults point at the Victus Cloud Lavalink node on DE-1.
# All values are optional; the defaults are baked into the bot config.
LAVALINK_HOST=135.125.222.36
LAVALINK_PORT=25578
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false
LAVALINK_ID=victus-de1
# Default search source: ytsearch (YouTube) or scsearch (SoundCloud)
LAVALINK_SEARCH=ytsearch
LAVALINK_VOLUME=80
